# Database
DATABASE_URL=sqlite:///./warroom.db

# App
APP_ENV=development
LOG_LEVEL=INFO
JWT_SECRET=

# LLM / Anthropic Claude  
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=           # Set to your Slack channel ID (e.g. C07XXXXXXXX)
SLACK_POLL_INTERVAL=10         # Seconds between polls

# Zoom
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# Google Calendar
GOOGLE_SERVICE_ACCOUNT_KEY=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Auth0 core
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# WarRoom Agent Backend M2M Application
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Token Vault / Custom API Client - ADD THESE
AUTH0_CUSTOM_API_CLIENT_ID=
AUTH0_CUSTOM_API_CLIENT_SECRET=
AUTH0_TOKEN_ENDPOINT=

GITHUB_APP_REMEDIATION_REPO=
GITHUB_APP_REMEDIATION_PATH=service-config.json
GITHUB_NETWORK_REMEDIATION_REPO=
GITHUB_NETWORK_REMEDIATION_PATH=network-policy.json

# Connection names
AUTH0_SLACK_CONNECTION_NAME=
AUTH0_GOOGLE_CONNECTION_NAME=
AUTH0_GITHUB_CONNECTION_NAME=

# Auth0 FGA
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=
FGA_MODEL_ID=
FGA_CLIENT_ID=
FGA_CLIENT_SECRET=
FGA_API_TOKEN_ISSUER=https://auth.fga.dev
FGA_API_AUDIENCE=https://api.us1.fga.dev/

# Auth0 CIBA
AUTH0_CIBA_ENABLED=true
AUTH0_CIBA_CLIENT_ID=
AUTH0_CIBA_CLIENT_SECRET=
AUTH0_CIBA_AUDIENCE=
AUTH0_CIBA_SCOPE=
AUTH0_CIBA_REQUESTED_EXPIRY=300
AUTH0_CIBA_DEFAULT_POLL_INTERVAL=5
AUTH0_APP_REMEDIATION_OWNER_SUB=
AUTH0_NETWORK_REMEDIATION_OWNER_SUB=


# CORS (frontend origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
